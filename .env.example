PUBLIC_BASE_URL=https://your-mcp-domain.example.com
PORT=8787

# Static OAuth client fallback. ChatGPT setup should normally use DCR instead.
OAUTH_CLIENT_ID=chatgpt
OAUTH_CLIENT_SECRET=<replace-with-random-hex>

# Password you type on this service's authorization page.
ADMIN_PASSWORD=<replace-with-random-password>

# Optional. Comma-separated redirect URI allowlist. Leave empty to allow
# ChatGPT-provided HTTPS redirect URIs during first setup.
ALLOWED_REDIRECT_URIS=

ACCESS_TOKEN_TTL_SECONDS=3600
AUTH_CODE_TTL_SECONDS=300
MAX_FILE_BYTES=1048576
MAX_SEARCH_RESULTS=50

# Cloudflare Tunnel token. Configure the tunnel public hostname to route to:
# http://chatgpt-docs-mcp:8787
CLOUDFLARED_TOKEN=<replace-with-cloudflare-tunnel-token>
